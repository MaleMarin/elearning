// Fix 3: Reglas de seguridad Firestore.
// Deploy: Firebase Console > Firestore > Reglas > pegar y publicar.
// O: firebase deploy --only firestore:rules (si tienes firebase.json con firestore.rules).
//
// Multitenancy: asigna custom claim request.auth.token.tenantId a cada usuario (ej. "shcp").
// Las colecciones que escopan por tenant deben tener campo tenantId; estas reglas lo exigen donde aplica.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Tenants: cada usuario solo puede leer el documento de su tenant (para UI personalizada).
    match /tenants/{tenantId} {
      allow read: if request.auth != null && request.auth.token.tenantId == tenantId;
      allow write: if false;
    }

    // Perfil: solo el propio usuario. Con multitenancy, token.tenantId y doc.tenantId deben coincidir.
    match /profiles/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId
        && (request.auth.token.get('tenantId', '') == '' || resource.data.get('tenantId', '') == request.auth.token.tenantId);
      allow create: if request.auth != null && request.auth.uid == userId
        && (request.auth.token.get('tenantId', '') == '' || request.resource.data.get('tenantId', '') == request.auth.token.tenantId);
      allow update, delete: if request.auth != null && request.auth.uid == userId
        && (request.auth.token.get('tenantId', '') == '' || resource.data.get('tenantId', '') == request.auth.token.tenantId);
    }

    // Progreso: documento id = '{uid}_{courseId}'. Solo el dueño puede leer/escribir.
    match /progress/{docId} {
      allow read, update, delete: if request.auth != null
        && docId.matches('^' + request.auth.uid + '_.*');
      allow create: if request.auth != null
        && docId.matches('^' + request.auth.uid + '_.*');
    }

    // Cursos: solo lectura de publicados. Escritura solo desde backend (Admin SDK).
    match /courses/{courseId} {
      allow read: if request.auth != null && resource.data.status == 'published';
      allow write: if false;
    }

    match /modules/{moduleId} {
      allow read: if request.auth != null && resource.data.status == 'published';
      allow write: if false;
    }

    match /lessons/{lessonId} {
      allow read: if request.auth != null && resource.data.status == 'published';
      allow write: if false;
    }

    // Cohorts, enrollments, invitations, etc.: sin acceso directo desde cliente.
    // Toda lectura/escritura debe ir por tu backend (API con Admin SDK).
    match /cohorts/{id} {
      allow read, write: if false;
    }
    match /cohort_courses/{id} {
      allow read, write: if false;
    }
    match /cohort_members/{id} {
      allow read, write: if false;
    }
    match /enrollments/{id} {
      allow read, write: if false;
    }
    match /invitations/{id} {
      allow read, write: if false;
    }

    // Audit logs: solo el usuario dueño o un admin puede leer; solo backend escribe
    match /users/{userId}/audit_logs/{logId} {
      allow read: if request.auth != null
        && (request.auth.uid == userId
          || get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'admin');
      allow write: if false;
    }

    // Brecha 1 — Cifrado E2E: diario y carta solo el dueño (contenido cifrado con llave del usuario)
    match /users/{userId}/journal/{entry} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/futureLetter/{doc} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/diagnostic/{doc} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/closingSurvey/{doc} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Brecha 2 — Simulador: resultados por usuario
    match /users/{userId}/simulations/{simId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Brecha 4 — Check-in cognitivo diario
    match /users/{userId}/checkins/{fecha} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Brecha 5 — Portafolio de transformación
    match /users/{userId}/portfolio/{projectId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Denegar todo lo no listado
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

# Entorno (development | staging | production). No hardcodear URLs ni keys.
NODE_ENV=development
# VERCEL_ENV=production   # Vercel lo define automáticamente

# Modo real: false = usa Supabase (cursos, enrollments, etc.). Reinicia el server tras cambiar.
NEXT_PUBLIC_DEMO_MODE=false

# Supabase (obligatorio para auth y DB en modo real)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# LLM (opcional: si no está, el asistente usa respuestas mock)
MODEL_API_KEY=
MODEL_API_BASE_URL=
MODEL_NAME=gpt-4o-mini

# MODEL_API_BASE_URL: deja vacío para OpenAI; para Azure/otros pon la URL base del endpoint compatible con chat/completions.

# URL pública del sitio (redirects, links). Preferir APP_URL.
APP_URL=http://localhost:3000
# NEXT_PUBLIC_SITE_URL=  # alternativa si no usas APP_URL

# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# Plantillas (nombres aprobados en Meta)
# WHATSAPP_TEMPLATE_SESSION_REMINDER=recordatorio_sesion
# WHATSAPP_TEMPLATE_TASK_REMINDER=recordatorio_tarea
# WHATSAPP_TEMPLATE_CERTIFICATE_READY=certificado_listo

# Cron manual: proteger con secret
# CRON_SECRET=

# Seed (solo STAGING)
# SEED_MODE=staging   # permite endpoint POST /api/seed y npm run seed:staging
# SEED_MODE=none      # en PROD: deshabilitar seed (por defecto)
# SEED_SECRET=        # obligatorio si SEED_MODE=staging; header x-seed-secret para POST /api/seed
# ADMIN_ID=           # opcional; UUID del admin en Auth (seed demo o prod)
# MENTOR_ID=         # opcional; solo staging
# STUDENT_ID=        # opcional; solo staging

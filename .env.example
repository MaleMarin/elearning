# =============================================================================
# E-learning Precisar — Variables de entorno
# Copia a .env.local y ajusta valores. Nunca subas .env.local a git.
# Tras cambiar .env.local, reinicia el servidor (npm run dev).
# =============================================================================
#
# Modo demo (sin Supabase): la app funciona con datos placeholder.
# - true  = no exige Supabase; ideal para probar en local sin BD.
# - false = modo real: usa Supabase; obligatorio tener NEXT_PUBLIC_SUPABASE_*.
#
# Para modo real en .env.local asegúrate de tener:
#   NEXT_PUBLIC_DEMO_MODE=false
#   NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
#   NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
NEXT_PUBLIC_DEMO_MODE=true

# Supabase (obligatorios en modo real; con DEMO_MODE=false)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# URL de la app (redirects, links)
APP_URL=http://localhost:3000

# Seed (staging = habilitar POST /api/seed; none = deshabilitar)
SEED_MODE=none
SEED_SECRET=

# Opcionales
# MODEL_API_KEY=           # IA / asistente
# WHATSAPP_ACCESS_TOKEN=
# CRON_SECRET=

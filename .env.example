# =============================================================================
# E-learning Precisar — Variables de entorno
# Copia a .env.local y ajusta valores. Nunca subas .env.local a git.
# Tras cambiar .env.local, reinicia el servidor (npm run dev).
# =============================================================================
#
# Modo demo: true = datos placeholder, sin login real.
# false = modo real con Firebase (Auth + Firestore).
#
NEXT_PUBLIC_DEMO_MODE=false

# Firebase (modo real). Desde Firebase Console > Configuración del proyecto > Tus apps.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (API routes). Firebase Console > Configuración > Cuentas de servicio > Generar nueva clave.
# Pega el JSON completo (una línea) o en base64.
FIREBASE_SERVICE_ACCOUNT_JSON=

# Arcjet: rate limiting en /api/auth/* (máx 10 intentos / 15 min). Obtener key en https://arcjet.com (gratis).
# Si no se define, no se aplica rate limit en middleware.
ARCJET_KEY=

# Cookie de sesión (demo + firma). Mínimo 32 caracteres en producción.
# Generar: openssl rand -base64 32
SESSION_SECRET=

# Sesión demo (Fix 4): JWT con expiración. Si no se define, se usa SESSION_SECRET.
# Generar: openssl rand -base64 32
DEMO_SESSION_SECRET=

# Credenciales admin en modo demo (/admin/login). Opcional; si no se definen, en demo cualquier correo/contraseña con role admin funciona.
DEMO_ADMIN_EMAIL=admin@demo.com
DEMO_ADMIN_PASSWORD=demo123

# URL de la app (redirects, links)
APP_URL=http://localhost:3000

# Seed (staging = habilitar POST /api/seed; none = deshabilitar)
SEED_MODE=none
SEED_SECRET=

# Sentry (errores y source maps). Valores reales solo en .env.local (nunca se sube).
# En Vercel: agregar NEXT_PUBLIC_SENTRY_DSN y SENTRY_AUTH_TOKEN en Settings → Environment Variables (sin esto Sentry no funciona en producción).
# DSN: Sentry → tu proyecto → Settings → Client Keys → copia la URL que empieza con https://
NEXT_PUBLIC_SENTRY_DSN=
# Auth Token: Sentry → Settings (arriba izq., org) → Auth Tokens → Create New Token → scope project:releases
SENTRY_AUTH_TOKEN=
# Org y project slugs (para subida de source maps en build). Ej: sentry.io/.../mi-org/projects/elearning-pd/
SENTRY_ORG=
SENTRY_PROJECT=

# Asistente multi-LLM (Vercel AI SDK). Solo configura las keys de los proveedores que quieras usar.
# Si ninguna está configurada, el selector no muestra opciones; en modo demo no se llama a ningún LLM.
# Anthropic (Claude)
ANTHROPIC_API_KEY=
# OpenAI (GPT-4o y voz: TTS + Whisper STT — Brecha 3)
OPENAI_API_KEY=
# Google (Gemini)
GOOGLE_GENERATIVE_AI_API_KEY=

# xAPI / LRS (analytics de aprendizaje). LRS gratuito: https://cloud.scorm.com (hasta 5,000 statements/mes).
XAPI_ENDPOINT=
XAPI_KEY=
XAPI_SECRET=

# Multitenancy / Superadmin. Solo esta cuenta puede acceder a /superadmin.
# SUPERADMIN_EMAIL=tu@email.com
# O lista de UIDs de Firebase: SUPERADMIN_UIDS=uid1,uid2

# Web Push (notificaciones en el navegador). Generar con: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=   (clave pública, en cliente)
# VAPID_PRIVATE_KEY=             (clave privada, solo servidor)
# VAPID_EMAIL=mailto:admin@politicadigital.gob.mx

# Daily.co — video en vivo (sesiones). Gratis hasta 1,000 min/mes.
# DAILY_API_KEY=

# Vercel KV (Redis) — opcional. Para limitar 1 petición activa por usuario en el asistente (/api/assistant).
# Crear en Vercel Dashboard → Storage → Create KV (o Upstash). Sin esto el asistente usa solo rate limit en memoria.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Opcionales
# MODEL_API_KEY=
# CRON_SECRET=
# =============================================================================
# E-learning Precisar — Variables de entorno
# Copia a .env.local y ajusta valores. Nunca subas .env.local a git.
# Para Vercel: Settings → Environment Variables (todas las que uses).
# =============================================================================

# ── DEMO MODE ──────────────────────────────────────────────────────────────
# false = producción con Firebase. true = datos placeholder, sin login real.
NEXT_PUBLIC_DEMO_MODE=false

# ── FIREBASE ───────────────────────────────────────────────────────────────
# Firebase Console > Configuración del proyecto > Tus apps
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (API routes). Cuentas de servicio > Generar nueva clave.
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── SUPABASE (opcional; mock si están vacías) ─────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── OPENAI ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── ANTHROPIC (Claude) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── GOOGLE (Gemini) ────────────────────────────────────────────────────────
GOOGLE_GENERATIVE_AI_API_KEY=

# ── GOOGLE DRIVE (asistente PD, carpeta de PDFs) ─────────────────────────────
GOOGLE_DRIVE_PDF_FOLDER_ID=
GOOGLE_APPLICATION_CREDENTIALS=./service-account-drive.json

# ── SEGURIDAD ───────────────────────────────────────────────────────────────
# Cookie de sesión / JWT. Mínimo 32 caracteres. Generar: openssl rand -base64 32
SESSION_SECRET=
JWT_SECRET=
DEMO_SESSION_SECRET=

# Arcjet: rate limiting en /api/auth/*. https://arcjet.com
ARCJET_KEY=

# ── SENTRY ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ── DAILY.CO (sesiones en vivo) ──────────────────────────────────────────────
DAILY_API_KEY=

# ── APP & SEED ──────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
SEED_MODE=none
SEED_SECRET=

# Credenciales admin en modo demo (/admin/login)
DEMO_ADMIN_EMAIL=admin@demo.com
DEMO_ADMIN_PASSWORD=demo123

# ── OPCIONALES ──────────────────────────────────────────────────────────────
# xAPI / LRS
XAPI_ENDPOINT=
XAPI_KEY=
XAPI_SECRET=

# Web Push
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@politicadigital.gob.mx

# Vercel KV (Redis) — asistente: 1 petición activa por usuario
KV_REST_API_URL=
KV_REST_API_TOKEN=

# PWA (desactivar en build si da problemas)
DISABLE_PWA=0

# ── Cron jobs (ejecutar reglas, etc.) ───────────────────────────────────────
# Cadena secreta para autorizar llamadas desde Vercel Cron o GitHub Actions
CRON_SECRET=
